# =============================================================================
# Orchestra Testbench workbench — copied to the Testbench skeleton as `.env`
# on first `composer run build` / `serve` when that skeleton has no `.env`.
#
# Laravel DB_* : Optional. Default `composer run build` does not run migrations.
# For workbench/seeders, install php-sqlite3, run workbench:create-sqlite-db, then migrate:fresh.
# Neo4j is not a replacement for Laravel's database connection.
#
# NEO4J_* : neo4j/laravel-boost reads these for Bolt + MCP (see config/neo4j-boost.php).
# Copy this file to `workbench/.env` and adjust (workbench/.env is gitignored).
# =============================================================================

APP_NAME="Neo4j Laravel Boost Workbench"
APP_ENV=local
APP_KEY=AckfSECXIvnK5r28GVIWUAxmbBSjTsmF
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE is set when Testbench runs create-sqlite-db; leave commented or use:
# DB_DATABASE="${APP_BASE_PATH}/database/database.sqlite"

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Neo4j database (Bolt) — used by this package / MCP subprocess transport
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password

# Neo4j MCP server (HTTP) — used when NEO4J_MCP_TRANSPORT=http
NEO4J_MCP_URL=http://localhost:8080/mcp
# NEO4J_MCP_USERNAME=
# NEO4J_MCP_PASSWORD=

# Neo4j MCP binary (config neo4j_mcp) — version and optional absolute path override
NEO4J_MCP_VERSION=v1.4.0
# NEO4J_MCP_BINARY_PATH=
