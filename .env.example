# Copy to .env when running the package locally (e.g. php artisan boost:mcp for e2e testing).
# Laravel Boost only registers its MCP command when APP_ENV=local or APP_DEBUG=true.

APP_NAME="Neo4j Boost"
APP_ENV=local
APP_DEBUG=true
APP_KEY=

# Neo4j MCP transport mode:
# - stdio (default): runs the local neo4j-mcp binary.
# - http: use when the MCP server runs elsewhere and NEO4J_MCP_URL points to it.
NEO4J_MCP_TRANSPORT=stdio

# Neo4j database credentials (required for STDIO mode — passed to the neo4j-mcp subprocess)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Optional: Neo4j MCP server URL when using HTTP transport (NEO4J_MCP_TRANSPORT=http)
# NEO4J_MCP_URL=http://localhost:8080/mcp
# NEO4J_MCP_USERNAME=neo4j
# NEO4J_MCP_PASSWORD=

# Container graph: direct Neo4j connection. Use NEO4J_URI, or set only NEO4J_DEFAULT_CONNECTION_DSN, e.g.:
# NEO4J_URI=bolt://localhost:7687
# NEO4J_DEFAULT_CONNECTION_DSN=neo4j://neo4j:password@neo4j-core1:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password
